<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" id="Definitions_HybridClassroom" targetNamespace="http://camunda.org/schema/lms" exporter="Camunda Modeler" exporterVersion="5.45.0">
  <bpmn:message id="Msg_QuizAnswer" name="QuizAnswerMessage" />
  <bpmn:process id="Process_HybridClassroom" name="Hybrid Classroom Process" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:laneSet id="LaneSet_HC">
      <bpmn:lane id="Lane_HC_Student" name="Student">
        <bpmn:flowNodeRef>Start_HC</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_Poll</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_TeamChallenge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_HC_QuizAnswer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_PostLectureQuiz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_HC_Complete</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>End_HC_Denied</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HC_Instructor" name="Instructor">
        <bpmn:flowNodeRef>Task_HC_StartLecture</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HC_LMS" name="LMS System">
        <bpmn:flowNodeRef>GW_HC_PrepSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_PrepareMaterials</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HC_PrepJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HC_EventBased</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Catch_HC_Timeout</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HC_AfterQuiz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HC_RewardSplit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_AwardPoints</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_SendFeedback</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_UpdateLeaderboard</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HC_RewardJoin</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_HC_PassFail</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_AwardBadge</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_Remedial</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HC_AI" name="AI Engine">
        <bpmn:flowNodeRef>Task_HC_AnalyzeClass</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_GenerateSummary</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_HC_LLM" name="LLM Tutor">
        <bpmn:flowNodeRef>Task_HC_GenerateInClassQuiz</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HC_GeneratePostQuiz</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="Start_HC" name="Lecture Scheduled">
      <bpmn:outgoing>F_HC_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="Task_HC_StartLecture" name="Start Lecture Session" camunda:formKey="camunda-forms:deployment:start-lecture.form" camunda:candidateGroups="instructor">
      <bpmn:incoming>F_HC_01</bpmn:incoming>
      <bpmn:outgoing>F_HC_02</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="GW_HC_PrepSplit" name="Prepare Lecture">
      <bpmn:incoming>F_HC_02</bpmn:incoming>
      <bpmn:outgoing>F_HC_03</bpmn:outgoing>
      <bpmn:outgoing>F_HC_04</bpmn:outgoing>
      <bpmn:outgoing>F_HC_05</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:serviceTask id="Task_HC_AnalyzeClass" name="Analyze Class Profile" camunda:type="external" camunda:topic="analyze-class-profile">
      <bpmn:incoming>F_HC_03</bpmn:incoming>
      <bpmn:outgoing>F_HC_06</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_HC_PrepareMaterials" name="Prepare Adaptive Lecture Materials" camunda:type="external" camunda:topic="prepare-lecture-materials">
      <bpmn:incoming>F_HC_04</bpmn:incoming>
      <bpmn:outgoing>F_HC_07</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_HC_GenerateInClassQuiz" name="Generate In-Class Quiz" camunda:type="external" camunda:topic="generate-inclass-quiz">
      <bpmn:incoming>F_HC_05</bpmn:incoming>
      <bpmn:outgoing>F_HC_08</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:parallelGateway id="GW_HC_PrepJoin" name="Lecture Ready to Begin">
      <bpmn:incoming>F_HC_06</bpmn:incoming>
      <bpmn:incoming>F_HC_07</bpmn:incoming>
      <bpmn:incoming>F_HC_08</bpmn:incoming>
      <bpmn:outgoing>F_HC_09</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:userTask id="Task_HC_Poll" name="Participate in Live Poll" camunda:formKey="camunda-forms:deployment:live-poll.form" camunda:assignee="${initiator}">
      <bpmn:incoming>F_HC_09</bpmn:incoming>
      <bpmn:outgoing>F_HC_10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_HC_TeamChallenge" name="Join Team Challenge" camunda:formKey="camunda-forms:deployment:team-challenge.form" camunda:assignee="${initiator}">
      <bpmn:incoming>F_HC_10</bpmn:incoming>
      <bpmn:outgoing>F_HC_11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:eventBasedGateway id="GW_HC_EventBased" name="Wait: Answer or Timeout">
      <bpmn:incoming>F_HC_11</bpmn:incoming>
      <bpmn:outgoing>F_HC_12</bpmn:outgoing>
      <bpmn:outgoing>F_HC_13</bpmn:outgoing>
    </bpmn:eventBasedGateway>
    <bpmn:intermediateCatchEvent id="Catch_HC_QuizAnswer" name="Student Answered Live Quiz">
      <bpmn:incoming>F_HC_12</bpmn:incoming>
      <bpmn:outgoing>F_HC_14</bpmn:outgoing>
      <bpmn:messageEventDefinition id="MsgDef_HC" messageRef="Msg_QuizAnswer" />
    </bpmn:intermediateCatchEvent>
    <bpmn:intermediateCatchEvent id="Catch_HC_Timeout" name="2 Min Quiz Timeout">
      <bpmn:incoming>F_HC_13</bpmn:incoming>
      <bpmn:outgoing>F_HC_15</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerDef_HC">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT2M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:intermediateCatchEvent>
    <bpmn:exclusiveGateway id="GW_HC_AfterQuiz" name="Quiz Processed">
      <bpmn:incoming>F_HC_14</bpmn:incoming>
      <bpmn:incoming>F_HC_15</bpmn:incoming>
      <bpmn:outgoing>F_HC_16</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:inclusiveGateway id="GW_HC_RewardSplit" name="Trigger Rewards and Feedback">
      <bpmn:incoming>F_HC_16</bpmn:incoming>
      <bpmn:outgoing>F_HC_17</bpmn:outgoing>
      <bpmn:outgoing>F_HC_18</bpmn:outgoing>
      <bpmn:outgoing>F_HC_19</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:serviceTask id="Task_HC_AwardPoints" name="Award Participation Points" camunda:type="external" camunda:topic="award-points">
      <bpmn:incoming>F_HC_17</bpmn:incoming>
      <bpmn:outgoing>F_HC_20</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_HC_SendFeedback" name="Send Real-Time Feedback" camunda:type="external" camunda:topic="send-realtime-feedback">
      <bpmn:incoming>F_HC_18</bpmn:incoming>
      <bpmn:outgoing>F_HC_21</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_HC_UpdateLeaderboard" name="Update Class Leaderboard" camunda:type="external" camunda:topic="update-leaderboard">
      <bpmn:incoming>F_HC_19</bpmn:incoming>
      <bpmn:outgoing>F_HC_22</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:inclusiveGateway id="GW_HC_RewardJoin" name="All Rewards Delivered">
      <bpmn:incoming>F_HC_20</bpmn:incoming>
      <bpmn:incoming>F_HC_21</bpmn:incoming>
      <bpmn:incoming>F_HC_22</bpmn:incoming>
      <bpmn:outgoing>F_HC_23</bpmn:outgoing>
    </bpmn:inclusiveGateway>
    <bpmn:serviceTask id="Task_HC_GenerateSummary" name="Generate AI Lecture Summary" camunda:type="external" camunda:topic="generate-lecture-summary">
      <bpmn:incoming>F_HC_23</bpmn:incoming>
      <bpmn:outgoing>F_HC_24</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_HC_GeneratePostQuiz" name="Generate Adaptive Post-Lecture Quiz" camunda:type="external" camunda:topic="generate-post-lecture-quiz">
      <bpmn:incoming>F_HC_24</bpmn:incoming>
      <bpmn:outgoing>F_HC_25</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_HC_PostLectureQuiz" name="Complete Post-Lecture Quiz" camunda:formKey="camunda-forms:deployment:post-lecture-quiz.form" camunda:assignee="${initiator}">
      <bpmn:incoming>F_HC_25</bpmn:incoming>
      <bpmn:outgoing>F_HC_26</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_HC_PassFail" name="Quiz Passed?" default="F_HC_Fail">
      <bpmn:incoming>F_HC_26</bpmn:incoming>
      <bpmn:outgoing>F_HC_Pass</bpmn:outgoing>
      <bpmn:outgoing>F_HC_Fail</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_HC_AwardBadge" name="Award Lecture Completion Badge" camunda:type="external" camunda:topic="award-completion-badge">
      <bpmn:incoming>F_HC_Pass</bpmn:incoming>
      <bpmn:outgoing>F_HC_27</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_HC_Remedial" name="Assign Remedial Content" camunda:type="external" camunda:topic="assign-remedial-content">
      <bpmn:incoming>F_HC_Fail</bpmn:incoming>
      <bpmn:outgoing>F_HC_28</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="End_HC_Complete" name="Lecture Complete - Passed">
      <bpmn:incoming>F_HC_27</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="End_HC_Denied" name="Lecture Complete - Remedial Assigned">
      <bpmn:incoming>F_HC_28</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="F_HC_01" sourceRef="Start_HC" targetRef="Task_HC_StartLecture" />
    <bpmn:sequenceFlow id="F_HC_02" sourceRef="Task_HC_StartLecture" targetRef="GW_HC_PrepSplit" />
    <bpmn:sequenceFlow id="F_HC_03" sourceRef="GW_HC_PrepSplit" targetRef="Task_HC_AnalyzeClass" />
    <bpmn:sequenceFlow id="F_HC_04" sourceRef="GW_HC_PrepSplit" targetRef="Task_HC_PrepareMaterials" />
    <bpmn:sequenceFlow id="F_HC_05" sourceRef="GW_HC_PrepSplit" targetRef="Task_HC_GenerateInClassQuiz" />
    <bpmn:sequenceFlow id="F_HC_06" sourceRef="Task_HC_AnalyzeClass" targetRef="GW_HC_PrepJoin" />
    <bpmn:sequenceFlow id="F_HC_07" sourceRef="Task_HC_PrepareMaterials" targetRef="GW_HC_PrepJoin" />
    <bpmn:sequenceFlow id="F_HC_08" sourceRef="Task_HC_GenerateInClassQuiz" targetRef="GW_HC_PrepJoin" />
    <bpmn:sequenceFlow id="F_HC_09" sourceRef="GW_HC_PrepJoin" targetRef="Task_HC_Poll" />
    <bpmn:sequenceFlow id="F_HC_10" sourceRef="Task_HC_Poll" targetRef="Task_HC_TeamChallenge" />
    <bpmn:sequenceFlow id="F_HC_11" sourceRef="Task_HC_TeamChallenge" targetRef="GW_HC_EventBased" />
    <bpmn:sequenceFlow id="F_HC_12" sourceRef="GW_HC_EventBased" targetRef="Catch_HC_QuizAnswer" />
    <bpmn:sequenceFlow id="F_HC_13" sourceRef="GW_HC_EventBased" targetRef="Catch_HC_Timeout" />
    <bpmn:sequenceFlow id="F_HC_14" sourceRef="Catch_HC_QuizAnswer" targetRef="GW_HC_AfterQuiz" />
    <bpmn:sequenceFlow id="F_HC_15" sourceRef="Catch_HC_Timeout" targetRef="GW_HC_AfterQuiz" />
    <bpmn:sequenceFlow id="F_HC_16" sourceRef="GW_HC_AfterQuiz" targetRef="GW_HC_RewardSplit" />
    <bpmn:sequenceFlow id="F_HC_17" sourceRef="GW_HC_RewardSplit" targetRef="Task_HC_AwardPoints" />
    <bpmn:sequenceFlow id="F_HC_18" sourceRef="GW_HC_RewardSplit" targetRef="Task_HC_SendFeedback" />
    <bpmn:sequenceFlow id="F_HC_19" sourceRef="GW_HC_RewardSplit" targetRef="Task_HC_UpdateLeaderboard" />
    <bpmn:sequenceFlow id="F_HC_20" sourceRef="Task_HC_AwardPoints" targetRef="GW_HC_RewardJoin" />
    <bpmn:sequenceFlow id="F_HC_21" sourceRef="Task_HC_SendFeedback" targetRef="GW_HC_RewardJoin" />
    <bpmn:sequenceFlow id="F_HC_22" sourceRef="Task_HC_UpdateLeaderboard" targetRef="GW_HC_RewardJoin" />
    <bpmn:sequenceFlow id="F_HC_23" sourceRef="GW_HC_RewardJoin" targetRef="Task_HC_GenerateSummary" />
    <bpmn:sequenceFlow id="F_HC_24" sourceRef="Task_HC_GenerateSummary" targetRef="Task_HC_GeneratePostQuiz" />
    <bpmn:sequenceFlow id="F_HC_25" sourceRef="Task_HC_GeneratePostQuiz" targetRef="Task_HC_PostLectureQuiz" />
    <bpmn:sequenceFlow id="F_HC_26" sourceRef="Task_HC_PostLectureQuiz" targetRef="GW_HC_PassFail" />
    <bpmn:sequenceFlow id="F_HC_Pass" name="Yes (&#62;=70)" sourceRef="GW_HC_PassFail" targetRef="Task_HC_AwardBadge">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${quizScore &gt;= 70}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_HC_Fail" name="No (&#60;70)" sourceRef="GW_HC_PassFail" targetRef="Task_HC_Remedial" />
    <bpmn:sequenceFlow id="F_HC_27" sourceRef="Task_HC_AwardBadge" targetRef="End_HC_Complete" />
    <bpmn:sequenceFlow id="F_HC_28" sourceRef="Task_HC_Remedial" targetRef="End_HC_Denied" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_HC">
    <bpmndi:BPMNPlane id="BPMNPlane_HC" bpmnElement="Process_HybridClassroom">
      <bpmndi:BPMNShape id="Lane_HC_LLM_di" bpmnElement="Lane_HC_LLM" isHorizontal="true">
        <dc:Bounds x="180" y="795" width="1780" height="155" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HC_AI_di" bpmnElement="Lane_HC_AI" isHorizontal="true">
        <dc:Bounds x="180" y="640" width="1780" height="155" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HC_LMS_di" bpmnElement="Lane_HC_LMS" isHorizontal="true">
        <dc:Bounds x="180" y="395" width="1780" height="245" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HC_Instructor_di" bpmnElement="Lane_HC_Instructor" isHorizontal="true">
        <dc:Bounds x="180" y="245" width="1780" height="150" />
        <bpmndi:BPMNLabel />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Lane_HC_Student_di" bpmnElement="Lane_HC_Student" isHorizontal="true">
        <dc:Bounds x="180" y="80" width="1780" height="165" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Start_HC_di" bpmnElement="Start_HC">
        <dc:Bounds x="232" y="145" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="207" y="188" width="86" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_StartLecture_di" bpmnElement="Task_HC_StartLecture">
        <dc:Bounds x="300" y="275" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HC_PrepSplit_di" bpmnElement="GW_HC_PrepSplit">
        <dc:Bounds x="495" y="492" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="464" y="549" width="112" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_AnalyzeClass_di" bpmnElement="Task_HC_AnalyzeClass">
        <dc:Bounds x="580" y="675" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_PrepareMaterials_di" bpmnElement="Task_HC_PrepareMaterials">
        <dc:Bounds x="580" y="470" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_GenerateInClassQuiz_di" bpmnElement="Task_HC_GenerateInClassQuiz">
        <dc:Bounds x="580" y="830" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HC_PrepJoin_di" bpmnElement="GW_HC_PrepJoin">
        <dc:Bounds x="680" y="492" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_Poll_di" bpmnElement="Task_HC_Poll">
        <dc:Bounds x="720" y="122" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_TeamChallenge_di" bpmnElement="Task_HC_TeamChallenge">
        <dc:Bounds x="900" y="122" width="130" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HC_EventBased_di" bpmnElement="GW_HC_EventBased">
        <dc:Bounds x="1045" y="492" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1015" y="549" width="110" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_HC_QuizAnswer_di" bpmnElement="Catch_HC_QuizAnswer">
        <dc:Bounds x="1110" y="108" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1088" y="151" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_HC_Timeout_di" bpmnElement="Catch_HC_Timeout">
        <dc:Bounds x="1110" y="502" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1090" y="545" width="76" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HC_AfterQuiz_di" bpmnElement="GW_HC_AfterQuiz" isMarkerVisible="true">
        <dc:Bounds x="1200" y="492" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HC_RewardSplit_di" bpmnElement="GW_HC_RewardSplit">
        <dc:Bounds x="1310" y="492" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1272" y="549" width="126" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_AwardPoints_di" bpmnElement="Task_HC_AwardPoints">
        <dc:Bounds x="1400" y="400" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_SendFeedback_di" bpmnElement="Task_HC_SendFeedback">
        <dc:Bounds x="1400" y="480" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_UpdateLeaderboard_di" bpmnElement="Task_HC_UpdateLeaderboard">
        <dc:Bounds x="1400" y="560" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HC_RewardJoin_di" bpmnElement="GW_HC_RewardJoin">
        <dc:Bounds x="1580" y="492" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_GenerateSummary_di" bpmnElement="Task_HC_GenerateSummary">
        <dc:Bounds x="1580" y="675" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_GeneratePostQuiz_di" bpmnElement="Task_HC_GeneratePostQuiz">
        <dc:Bounds x="1350" y="830" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_PostLectureQuiz_di" bpmnElement="Task_HC_PostLectureQuiz">
        <dc:Bounds x="1500" y="122" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_HC_PassFail_di" bpmnElement="GW_HC_PassFail" isMarkerVisible="true">
        <dc:Bounds x="1670" y="492" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1659" y="549" width="72" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_AwardBadge_di" bpmnElement="Task_HC_AwardBadge">
        <dc:Bounds x="1760" y="400" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HC_Remedial_di" bpmnElement="Task_HC_Remedial">
        <dc:Bounds x="1760" y="490" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_HC_Complete_di" bpmnElement="End_HC_Complete">
        <dc:Bounds x="1712" y="108" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1688" y="151" width="84" height="27" />
