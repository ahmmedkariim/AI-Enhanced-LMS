        <di:waypoint x="740" y="725" />
        <di:waypoint x="795" y="725" />
        <di:waypoint x="795" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_07_di" bpmnElement="F_AL_07">
        <di:waypoint x="740" y="560" />
        <di:waypoint x="795" y="560" />
        <di:waypoint x="795" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_08_di" bpmnElement="F_AL_08">
        <di:waypoint x="820" y="355" />
        <di:waypoint x="875" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_09_di" bpmnElement="F_AL_09">
        <di:waypoint x="900" y="330" />
        <di:waypoint x="900" y="300" />
        <di:waypoint x="975" y="300" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_10_di" bpmnElement="F_AL_10">
