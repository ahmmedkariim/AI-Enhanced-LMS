        <di:waypoint x="1105" y="375" />
        <di:waypoint x="1160" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_14_di" bpmnElement="F_AL_14">
        <di:waypoint x="1105" y="450" />
        <di:waypoint x="1185" y="450" />
        <di:waypoint x="1185" y="380" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_15_di" bpmnElement="F_AL_15">
        <di:waypoint x="1185" y="330" />
