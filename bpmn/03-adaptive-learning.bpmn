          <dc:Bounds x="1358" y="338" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Catch_AL_Timeout_di" bpmnElement="Catch_AL_Timeout">
        <dc:Bounds x="1382" y="377" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1358" y="420" width="85" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_AL_AfterEvent_di" bpmnElement="GW_AL_AfterEvent" isMarkerVisible="true">
        <dc:Bounds x="1480" y="330" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AL_TrackProgress_di" bpmnElement="Task_AL_TrackProgress">
        <dc:Bounds x="1470" y="520" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AL_AdjustDifficultyDMN_di" bpmnElement="Task_AL_AdjustDifficultyDMN">
        <dc:Bounds x="1580" y="310" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="GW_AL_Continue_di" bpmnElement="GW_AL_Continue" isMarkerVisible="true">
        <dc:Bounds x="1692" y="330" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1670" y="387" width="95" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="End_AL_Session_di" bpmnElement="End_AL_Session">
        <dc:Bounds x="1712" y="145" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1685" y="188" width="90" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="F_AL_01_di" bpmnElement="F_AL_01">
        <di:waypoint x="250" y="181" />
        <di:waypoint x="250" y="560" />
        <di:waypoint x="220" y="560" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_02_di" bpmnElement="F_AL_02">
        <di:waypoint x="290" y="560" />
        <di:waypoint x="340" y="560" />
        <di:waypoint x="340" y="350" />
        <di:waypoint x="360" y="350" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_03_di" bpmnElement="F_AL_03">
        <di:waypoint x="500" y="350" />
        <di:waypoint x="555" y="355" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="F_AL_04_di" bpmnElement="F_AL_04">
        <di:waypoint x="580" y="380" />
        <di:waypoint x="580" y="725" />
        <di:waypoint x="600" y="725" />
      </bpmndi:BPMNEdge>
