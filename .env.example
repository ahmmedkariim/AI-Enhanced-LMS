# ============================================
# Camunda Configuration
# ============================================
CAMUNDA_REST_URL=http://localhost:8080/engine-rest
CAMUNDA_USERNAME=demo
CAMUNDA_PASSWORD=demo

# ============================================
# Worker Configuration
# ============================================
WORKER_ID=python-worker-1
MAX_TASKS=10
LOCK_DURATION=10000
ASYNC_RESPONSE_TIMEOUT=5000

# ============================================
# Email Service (Gmail SMTP)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_NAME=AI-Enhanced LMS
# NOTE: For Gmail, generate an App Password at:
# https://myaccount.google.com/apppasswords

# ============================================
# AI / LLM Services (optional - for real integration)
# ============================================
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Set to 'mock' to use built-in mock responses (recommended for demo)
AI_MODE=mock
LLM_MODE=mock

# ============================================
# Database
# ============================================
DATABASE_URL=sqlite:///./data/lms.db
