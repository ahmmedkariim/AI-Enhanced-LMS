{
  "schemaVersion": 2,
  "exporter": {
    "name": "Camunda Modeler",
    "version": "5.21.0"
  },
  "id": "form-enter-credentials",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 🎓 AI-Enhanced LMS — Login\nPlease enter your credentials to access the system.",
      "id": "text-header"
    },
    {
      "type": "textfield",
      "id": "username",
      "key": "username",
      "label": "Username",
      "description": "Your LMS username (e.g. johndoe)",
      "validate": {
        "required": true,
        "minLength": 3
      }
    },
    {
      "type": "textfield",
      "id": "password",
      "key": "password",
      "label": "Password",
      "description": "Minimum 6 characters",
      "validate": {
        "required": true,
        "minLength": 6
      }
    },
    {
      "type": "select",
      "id": "userType",
      "key": "userType",
      "label": "Account Type",
      "defaultValue": "student",
      "values": [
        { "label": "🎓 Student",    "value": "student" },
        { "label": "👨‍🏫 Instructor", "value": "instructor" },
        { "label": "🛡️ Admin",      "value": "admin" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "select",
      "id": "emailDomain",
      "key": "emailDomain",
      "label": "Email Domain",
      "defaultValue": "student.lms.edu",
      "values": [
        { "label": "student.lms.edu",   "value": "student.lms.edu" },
        { "label": "faculty.lms.edu",   "value": "faculty.lms.edu" },
        { "label": "admin.lms.edu",     "value": "admin.lms.edu" }
      ]
    }
  ]
}
