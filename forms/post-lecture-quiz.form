{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-post-lecture-quiz",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 📝 Post-Lecture Quiz\nThis quiz was generated by the LLM Tutor based on today's lecture content. Your score updates your adaptive learning path.",
      "id": "text-header"
    },
    {
      "type": "number",
      "id": "quizScore",
      "key": "quizScore",
      "label": "Your Quiz Score (%)",
      "description": "Enter your score (0-100)",
      "defaultValue": 0,
      "validate": { "required": true, "min": 0, "max": 100 }
    },
    {
      "type": "select",
      "id": "quizScoreLevel",
      "key": "quizScoreLevel",
      "label": "Score Level",
      "defaultValue": "Medium",
      "values": [
        { "label": "🏆 High (70% and above)",    "value": "High" },
        { "label": "📈 Medium (40% to 69%)",     "value": "Medium" },
        { "label": "📉 Low (below 40%)",         "value": "Low" }
      ],
      "validate": { "required": true }
    }
  ]
}
