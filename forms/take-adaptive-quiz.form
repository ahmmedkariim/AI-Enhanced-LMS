{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-take-adaptive-quiz",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 🤖 AI-Generated Adaptive Quiz\nThis quiz was created by the LLM Tutor specifically for you. The difficulty was set by DMN 4 based on your past performance.",
      "id": "text-header"
    },
    {
      "type": "textfield",
      "id": "nextDifficulty",
      "key": "nextDifficulty",
      "label": "Quiz Difficulty",
      "description": "Set by DMN 4: Quiz Difficulty Adjustment",
      "disabled": true
    },
    {
      "type": "number",
      "id": "questionCount",
      "key": "questionCount",
      "label": "Number of Questions",
      "disabled": true
    },
    {
      "type": "text",
      "text": "---\n### Q1: {{ q1Text }}\n- **A** — {{ q1OptA }}\n- **B** — {{ q1OptB }}\n- **C** — {{ q1OptC }}\n- **D** — {{ q1OptD }}",
      "id": "text-q1"
    },
    {
      "type": "select",
      "id": "q1Answer",
      "key": "q1Answer",
      "label": "Your answer to Q1",
      "values": [
        { "label": "A", "value": "0" },
        { "label": "B", "value": "1" },
        { "label": "C", "value": "2" },
        { "label": "D", "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "text",
      "text": "---\n### Q2: {{ q2Text }}\n- **A** — {{ q2OptA }}\n- **B** — {{ q2OptB }}\n- **C** — {{ q2OptC }}\n- **D** — {{ q2OptD }}",
      "id": "text-q2"
    },
    {
      "type": "select",
      "id": "q2Answer",
      "key": "q2Answer",
      "label": "Your answer to Q2",
      "values": [
        { "label": "A", "value": "0" },
        { "label": "B", "value": "1" },
        { "label": "C", "value": "2" },
        { "label": "D", "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "text",
      "text": "---\n### Q3: {{ q3Text }}\n- **A** — {{ q3OptA }}\n- **B** — {{ q3OptB }}\n- **C** — {{ q3OptC }}\n- **D** — {{ q3OptD }}",
      "id": "text-q3"
    },
    {
      "type": "select",
      "id": "q3Answer",
      "key": "q3Answer",
      "label": "Your answer to Q3",
      "values": [
        { "label": "A", "value": "0" },
        { "label": "B", "value": "1" },
        { "label": "C", "value": "2" },
        { "label": "D", "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "text",
      "text": "---\n### Q4: {{ q4Text }}\n- **A** — {{ q4OptA }}\n- **B** — {{ q4OptB }}\n- **C** — {{ q4OptC }}\n- **D** — {{ q4OptD }}",
      "id": "text-q4"
    },
    {
      "type": "select",
      "id": "q4Answer",
      "key": "q4Answer",
      "label": "Your answer to Q4",
      "values": [
        { "label": "A", "value": "0" },
        { "label": "B", "value": "1" },
        { "label": "C", "value": "2" },
        { "label": "D", "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "text",
      "text": "---\n### Q5: {{ q5Text }}\n- **A** — {{ q5OptA }}\n- **B** — {{ q5OptB }}\n- **C** — {{ q5OptC }}\n- **D** — {{ q5OptD }}",
      "id": "text-q5"
    },
    {
      "type": "select",
      "id": "q5Answer",
      "key": "q5Answer",
      "label": "Your answer to Q5",
      "values": [
        { "label": "A", "value": "0" },
        { "label": "B", "value": "1" },
        { "label": "C", "value": "2" },
        { "label": "D", "value": "3" }
      ],
      "validate": { "required": true }
    }
  ]
}
