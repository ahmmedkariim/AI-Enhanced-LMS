{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-take-adaptive-quiz",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 🤖 AI-Generated Adaptive Quiz\nThis quiz was created by the LLM Tutor specifically for you. The difficulty was set by DMN 4 based on your past performance.",
      "id": "text-header"
    },
    {
      "type": "textfield",
      "id": "nextDifficulty",
      "key": "nextDifficulty",
      "label": "Quiz Difficulty",
      "description": "Set by DMN 4: Quiz Difficulty Adjustment",
      "disabled": true
    },
    {
      "type": "number",
      "id": "questionCount",
      "key": "questionCount",
      "label": "Number of Questions",
      "disabled": true
    },
    {
      "type": "text",
      "text": "---\n### Answer the following questions:\n*(In a real system, questions load dynamically from the LLM)*",
      "id": "text-questions"
    },
    {
      "type": "select",
      "id": "q1Answer",
      "key": "q1Answer",
      "label": "Q1: What is the hit policy FIRST in DMN?",
      "values": [
        { "label": "A — All matching rules fire",               "value": "0" },
        { "label": "B — Only the first matching rule fires",    "value": "1" },
        { "label": "C — Rules are ranked by priority",         "value": "2" },
        { "label": "D — A random rule fires",                  "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "select",
      "id": "q2Answer",
      "key": "q2Answer",
      "label": "Q2: What does a Parallel Gateway do in BPMN?",
      "values": [
        { "label": "A — Routes to only one branch",            "value": "0" },
        { "label": "B — Fires all outgoing branches at once",  "value": "1" },
        { "label": "C — Waits for an event to occur",         "value": "2" },
        { "label": "D — Routes based on conditions",          "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "select",
      "id": "q3Answer",
      "key": "q3Answer",
      "label": "Q3: What is an External Task in Camunda?",
      "values": [
        { "label": "A — A task inside the engine",             "value": "0" },
        { "label": "B — A task completed by an external worker polling via REST", "value": "1" },
        { "label": "C — A task assigned to another process",  "value": "2" },
        { "label": "D — A manual task with no automation",    "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "select",
      "id": "q4Answer",
      "key": "q4Answer",
      "label": "Q4: What is the purpose of an Inclusive Gateway?",
      "values": [
        { "label": "A — Routes to exactly one path",                   "value": "0" },
        { "label": "B — Routes to all paths simultaneously",           "value": "1" },
        { "label": "C — Routes to one or more paths based on conditions", "value": "2" },
        { "label": "D — Waits for a timer",                            "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "select",
      "id": "q5Answer",
      "key": "q5Answer",
      "label": "Q5: What does BPMN stand for?",
      "values": [
        { "label": "A — Business Process Model and Notation",  "value": "0" },
        { "label": "B — Basic Process Management Node",        "value": "1" },
        { "label": "C — Business Programming Model Network",   "value": "2" },
        { "label": "D — Binary Process Mapping Notation",      "value": "3" }
      ],
      "validate": { "required": true }
    },
    {
      "type": "number",
      "id": "timeSpentSeconds",
      "key": "timeSpentSeconds",
      "label": "Time spent (seconds)",
      "defaultValue": 120,
      "validate": { "required": true, "min": 10 }
    }
  ]
}
