{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-live-poll",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 📊 Live Lecture Poll\nYour instructor has launched a real-time poll. Answer quickly — results update instantly!",
      "id": "text-header"
    },
    {
      "type": "textfield",
      "id": "pollQuestion",
      "key": "pollQuestion",
      "label": "Poll Question",
      "description": "Generated by AI based on lecture content",
      "disabled": true
    },
    {
      "type": "select",
      "id": "pollAnswer",
      "key": "pollAnswer",
      "label": "Your Answer",
      "values": [
        { "label": "A — Strongly Agree / Very Confident",   "value": "A" },
        { "label": "B — Agree / Somewhat Confident",        "value": "B" },
        { "label": "C — Neutral / Unsure",                  "value": "C" },
        { "label": "D — Disagree / Not Confident",          "value": "D" }
      ],
      "validate": { "required": true }
    }
  ]
}
