{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-access-materials",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 🎓 Your Personalized Learning Materials\nBased on your profile and the DMN learning-path decision, here is what's been assigned to you.",
      "id": "text-header"
    },
    {
      "type": "textfield",
      "id": "nextLearningPath",
      "key": "nextLearningPath",
      "label": "Current Learning Path",
      "description": "Assigned by DMN 1: Learning Path Decision",
      "disabled": true
    },
    {
      "type": "textfield",
      "id": "primaryContentName",
      "key": "primaryContentName",
      "label": "Primary Module",
      "disabled": true
    },
    {
      "type": "textfield",
      "id": "practiceName",
      "key": "practiceName",
      "label": "Practice Exercise",
      "disabled": true
    },
    {
      "type": "text",
      "text": "---\n**Mark this learning activity as completed to continue the process:**",
      "id": "text-divider"
    },
    {
      "type": "checkbox",
      "id": "activityCompleted",
      "key": "activityCompleted",
      "label": "I have reviewed the materials above and completed this study session",
      "defaultValue": true,
      "validate": { "required": true }
    }
  ]
}
