{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-team-challenge",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 🤝 Team Challenge\nAI has assigned you to a team based on your personality profile.",
      "id": "text-header"
    },
    {
      "type": "textfield",
      "id": "teamName",
      "key": "teamName",
      "label": "Your team",
      "description": "Assigned by AI based on personality profile",
      "disabled": true
    },
    {
      "type": "textfield",
      "id": "challengeTitle",
      "key": "challengeTitle",
      "label": "Challenge title",
      "disabled": true
    },
    {
      "type": "text",
      "text": "### 🧩 The challenge\n{{ challengeProblem }}",
      "id": "text-challenge-body"
    },
    {
      "type": "textarea",
      "id": "challengeResponse",
      "key": "challengeResponse",
      "label": "Your team's response",
      "description": "Submit your team's answer to the challenge above",
      "validate": { "required": true }
    },
    {
      "type": "select",
      "id": "collaborationLevel",
      "key": "collaborationLevel",
      "label": "How well did your team collaborate?",
      "defaultValue": "High",
      "values": [
        { "label": "🌟 High — Everyone contributed equally",   "value": "High" },
        { "label": "📈 Medium — Most members contributed",     "value": "Medium" },
        { "label": "📉 Low — Limited team participation",      "value": "Low" }
      ],
      "validate": { "required": true }
    }
  ]
}
