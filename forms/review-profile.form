{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-review-profile",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 🤖 Your AI-Generated Learning Profile\nOur AI has analyzed your goals and learning style. Please review your personalized plan below.",
      "id": "text-header"
    },
    {
      "type": "textfield",
      "id": "assignedPath",
      "key": "assignedPath",
      "label": "Assigned Learning Path",
      "description": "Generated by AI + DMN decision engine",
      "disabled": true
    },
    {
      "type": "textarea",
      "id": "recommendedResources",
      "key": "recommendedResources",
      "label": "Recommended Resources",
      "description": "Curated by AI based on your learning style",
      "disabled": true
    },
    {
      "type": "text",
      "text": "---\n**Does this plan look correct to you?**",
      "id": "text-confirm"
    },
    {
      "type": "checkbox",
      "id": "profileApproved",
      "key": "profileApproved",
      "label": "Yes, my profile looks correct — start my learning journey!",
      "defaultValue": true,
      "validate": { "required": true }
    }
  ]
}
