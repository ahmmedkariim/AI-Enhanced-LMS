{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-quiz-result",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## 🎯 Your Quiz Result\nHere's how you did on the adaptive quiz.",
      "id": "text-header"
    },
    {
      "type": "number",
      "id": "quizScore",
      "key": "quizScore",
      "label": "Your Score (%)",
      "disabled": true
    },
    {
      "type": "textfield",
      "id": "quizScoreLevel",
      "key": "quizScoreLevel",
      "label": "Performance Level",
      "description": "High / Medium / Low",
      "disabled": true
    },
    {
      "type": "checkbox",
      "id": "quizPassed",
      "key": "quizPassed",
      "label": "Passed (>= 60%)",
      "disabled": true
    },
    {
      "type": "textarea",
      "id": "resultSummary",
      "key": "resultSummary",
      "label": "AI Feedback",
      "description": "Generated by the LLM Tutor based on your performance",
      "disabled": true
    },
    {
      "type": "textarea",
      "id": "studyTips",
      "key": "studyTips",
      "label": "Study Tips",
      "description": "Personalized to your learning style (only set when remedial path was taken)",
      "disabled": true
    },
    {
      "type": "text",
      "text": "---\n**Acknowledge to complete the process:**",
      "id": "text-acknowledge"
    },
    {
      "type": "checkbox",
      "id": "resultAcknowledged",
      "key": "resultAcknowledged",
      "label": "I have reviewed my quiz result",
      "defaultValue": true,
      "validate": { "required": true }
    }
  ]
}
