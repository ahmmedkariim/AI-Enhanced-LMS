{
  "schemaVersion": 2,
  "exporter": { "name": "Camunda Modeler", "version": "5.21.0" },
  "id": "form-show-error",
  "type": "default",
  "components": [
    {
      "type": "text",
      "text": "## ❌ Login Failed\nYour credentials are invalid. Please check and try again.",
      "id": "text-error-header"
    },
    {
      "type": "textfield",
      "id": "errorMessage",
      "key": "errorMessage",
      "label": "Error Details",
      "defaultValue": "Invalid username, password, or account type.",
      "disabled": true
    },
    {
      "type": "text",
      "text": "**Demo credentials:**\n- Student: `ahmed` / `Password123!`\n- Instructor: `drsara` / `Password123!`\n- Admin: `systemadmin` / `Admin456!`",
      "id": "text-hint"
    }
  ]
}
